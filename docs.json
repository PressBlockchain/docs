{
  "$schema": "https://mintlify.com/docs.json",
  "name": "PressChain",
  "theme": "mint",
  "logo": {
    "light": "https://presschain.io/Main.png",
    "dark": "https://presschain.io/Main.png",
    "href": "https://docs.presschain.io"
  },
  "favicon": "https://presschain.io/Main.png",
  "colors": {
    "primary": "#009BF9",
    "light": "#38B6FF",
    "dark": "#002A43"
  },
  "topbar": {
    "links": [
      {
        "name": "Explorer",
        "url": "https://explorer.presschain.io"
      },
      {
        "name": "Status",
        "url": "https://status.presschain.io"
      }
    ],
    "cta": {
      "name": "Open Portal \u2192",
      "url": "https://portal.presschain.io"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/PressBlockchain/",
          "icon": "github"
        },
        {
          "anchor": "Bridge API",
          "href": "https://bridge.presschain.io/health",
          "icon": "webhook"
        },
        {
          "anchor": "Faucet",
          "href": "https://faucet.presschain.io",
          "icon": "droplet"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@presschain.io",
          "icon": "envelope"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Developer",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "developer/introduction",
              "developer/quickstart"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "developer/architecture/overview",
              "developer/architecture/domains",
              "developer/architecture/infrastructure"
            ]
          },
          {
            "group": "Chain & Network",
            "pages": [
              "developer/chain/config",
              "developer/chain/rpc",
              "developer/chain/contracts",
              "developer/chain/abis"
            ]
          },
          {
            "group": "The Capsule",
            "pages": [
              "developer/capsule/standard",
              "developer/capsule/acceptance",
              "developer/capsule/lifecycle"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "developer/integrations/bridge-api",
              "developer/integrations/presskey",
              "developer/integrations/events",
              "developer/integrations/wordpress"
            ]
          },
          {
            "group": "Operators",
            "pages": [
              "developer/operators/deployment",
              "developer/operators/environment",
              "developer/operators/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "For Journalists",
        "groups": [
          {
            "group": "Start Here",
            "pages": [
              "journalist/welcome",
              "journalist/presskey-setup"
            ]
          },
          {
            "group": "Your Stories",
            "pages": [
              "journalist/capsules/what-is-a-capsule",
              "journalist/capsules/publish-your-first-story",
              "journalist/capsules/evidence-and-sources",
              "journalist/capsules/corrections"
            ]
          },
          {
            "group": "Public Voting",
            "pages": [
              "journalist/voting/how-voting-works",
              "journalist/voting/reputation"
            ]
          },
          {
            "group": "Disputes & Integrity",
            "pages": [
              "journalist/court/disputes",
              "journalist/court/integrity-labels"
            ]
          },
          {
            "group": "Running an Outlet",
            "pages": [
              "journalist/outlets/register-your-newsroom",
              "journalist/outlets/domain-verification",
              "journalist/outlets/wordpress-guide",
              "journalist/outlets/syndication"
            ]
          },
          {
            "group": "Earning Revenue",
            "pages": [
              "journalist/money/overview",
              "journalist/money/rights-licensing",
              "journalist/money/ads"
            ]
          },
          {
            "group": "Roles & Standing",
            "pages": [
              "journalist/roles/overview",
              "journalist/roles/bonds",
              "journalist/roles/penalties"
            ]
          }
        ]
      }
    ]
  },
  "css": "/_styles/custom.css",
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "search": {
    "prompt": "Search PressChain docs..."
  },
  "footer": {
    "socials": {
      "twitter": "https://twitter.com/presschain_io",
      "github": "https://github.com/PressBlockchain/"
    }
  }
}